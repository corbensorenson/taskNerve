#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
tasknerve GUI launcher

Usage:
  tasknerve-gui [options]

Options:
  --repo-root <path>   Repo root context for the GUI server (default: $TASKNERVE_GUI_ROOT or $HOME)
  --project <name>     Open a specific registered project instead of the most recent one
  --host <host>        Bind host for the GUI server (default: $TASKNERVE_GUI_HOST or 127.0.0.1)
  --port <port>        Bind port for the GUI server (default: $TASKNERVE_GUI_PORT or 0 for auto)
  --no-open            Start the GUI server without opening a browser tab
  -h, --help           Show this help
USAGE
}

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_BIN="$SCRIPT_DIR/tasknerve"
TASKNERVE_BIN="${TASKNERVE_BIN:-}"
GUI_ROOT="${TASKNERVE_GUI_ROOT:-${HOME:-.}}"
GUI_PROJECT="${TASKNERVE_GUI_PROJECT:-}"
GUI_HOST="${TASKNERVE_GUI_HOST:-127.0.0.1}"
GUI_PORT="${TASKNERVE_GUI_PORT:-0}"
NO_OPEN=0

if [[ -z "$TASKNERVE_BIN" ]]; then
  if [[ -x "$DEFAULT_BIN" ]]; then
    TASKNERVE_BIN="$DEFAULT_BIN"
  else
    TASKNERVE_BIN="$(command -v tasknerve || true)"
  fi
fi

if [[ -z "$TASKNERVE_BIN" ]]; then
  echo "tasknerve-gui could not find the tasknerve binary. Reinstall tasknerve or set TASKNERVE_BIN." >&2
  exit 1
fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo-root)
      GUI_ROOT="$2"
      shift 2
      ;;
    --project)
      GUI_PROJECT="$2"
      shift 2
      ;;
    --host)
      GUI_HOST="$2"
      shift 2
      ;;
    --port)
      GUI_PORT="$2"
      shift 2
      ;;
    --no-open)
      NO_OPEN=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage
      exit 1
      ;;
  esac
done

"$TASKNERVE_BIN" project discover >/dev/null 2>&1 || true

ARGS=(--repo-root "$GUI_ROOT" task gui --background --host "$GUI_HOST" --port "$GUI_PORT")
if [[ -n "$GUI_PROJECT" ]]; then
  ARGS+=(--project "$GUI_PROJECT")
fi
if [[ "$NO_OPEN" -eq 1 ]]; then
  ARGS+=(--no-open)
fi

exec "$TASKNERVE_BIN" "${ARGS[@]}"
